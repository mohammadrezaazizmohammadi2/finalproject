<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.divarclone.client.controller.AdCardController"
      spacing="8"
      prefWidth="220"
      maxWidth="220"
      style="-fx-background-color: white;
             -fx-background-radius: 10;
             -fx-border-color: #EAEAEA;
             -fx-border-radius: 10;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <ImageView fx:id="imageView"
               fitWidth="196"
               fitHeight="120"
               preserveRatio="true"/>


    <Label fx:id="titleLabel"
           wrapText="true"
           style="-fx-font-size:16px;
              -fx-font-weight:bold;
              -fx-text-fill:#000000;"/>

    <Label fx:id="categoryLabel"
           style="-fx-text-fill:#000000; -fx-font-size:12px; -fx-font-weight:bold;"/>

    <Label fx:id="priceLabel"
           style="-fx-text-fill:#6B8E23; -fx-font-weight:bold; -fx-font-size:14px;"/>

    <Label fx:id="cityLabel"
           style="-fx-text-fill:#000000; -fx-font-weight:bold;"/>

    <Label fx:id="statusLabel"
           style="-fx-font-weight:bold;"
           visible="false"
           managed="false"/>

    <HBox fx:id="actionsBox"
          spacing="8"
          visible="false"
          managed="false">

        <Button fx:id="deleteButton"
                text="Delete"
                visible="false"
                managed="false"
                onAction="#onDeleteClicked"/>

        <Button fx:id="markSoldButton"
                text="Mark Sold"
                visible="false"
                managed="false"
                onAction="#onMarkSoldClicked"/>


    </HBox>

</VBox>