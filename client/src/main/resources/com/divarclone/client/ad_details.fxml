<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.divarclone.client.controller.AdDetailsController">

    <top>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Close" onAction="#handleClose"/>
        </HBox>
    </top>

    <center>

        <VBox spacing="15" alignment="TOP_CENTER">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <ImageView fx:id="imageView"
                       fitWidth="300"
                       fitHeight="220"
                       preserveRatio="true"/>

            <Label fx:id="titleLabel"
                   style="-fx-font-size:22px;-fx-font-weight:bold;"/>

            <Label fx:id="priceLabel"/>

            <Label fx:id="cityLabel"/>

            <Label fx:id="statusLabel"/>

            <Label fx:id="ownerLabel"
                   style="-fx-font-size:11px; -fx-text-fill:#999999;"/>

            <HBox fx:id="starsBox" spacing="4" alignment="CENTER">
                <Label fx:id="star1" text="☆" style="-fx-font-size:22px; -fx-text-fill:#CCAA00;" onMouseClicked="#rateStar1"/>
                <Label fx:id="star2" text="☆" style="-fx-font-size:22px; -fx-text-fill:#CCAA00;" onMouseClicked="#rateStar2"/>
                <Label fx:id="star3" text="☆" style="-fx-font-size:22px; -fx-text-fill:#CCAA00;" onMouseClicked="#rateStar3"/>
                <Label fx:id="star4" text="☆" style="-fx-font-size:22px; -fx-text-fill:#CCAA00;" onMouseClicked="#rateStar4"/>
                <Label fx:id="star5" text="☆" style="-fx-font-size:22px; -fx-text-fill:#CCAA00;" onMouseClicked="#rateStar5"/>
            </HBox>

            <Label fx:id="ratingSummaryLabel"
                   style="-fx-font-size:11px; -fx-text-fill:#999999;"/>


            <Label text="Description"
                   style="-fx-font-size:18px;-fx-font-weight:bold;"/>

            <Label fx:id="descriptionLabel"
                   wrapText="true"/>

        </VBox>

    </center>

</BorderPane>