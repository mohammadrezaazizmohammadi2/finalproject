<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.divarclone.client.controller.AdminPanelController">

    <top>
        <HBox spacing="10.0">
            <padding>
                <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
            </padding>
            <Button text="Back to Main" onAction="#handleBackToMain"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="Pending Ads">
                <TableView fx:id="pendingAdsTable">
                    <columns>
                        <TableColumn fx:id="pendingTitleColumn" text="Title" prefWidth="200"/>
                        <TableColumn fx:id="pendingPriceColumn" text="Price" prefWidth="100"/>
                        <TableColumn fx:id="pendingCityColumn" text="City" prefWidth="100"/>
                        <TableColumn fx:id="pendingOwnerColumn" text="Owner ID" prefWidth="80"/>
                        <TableColumn fx:id="pendingActionsColumn" text="Actions" prefWidth="180"/>
                    </columns>
                </TableView>
            </Tab>

            <Tab text="Users">
                <TableView fx:id="usersTable">
                    <columns>
                        <TableColumn fx:id="usernameColumn" text="Username" prefWidth="150"/>
                        <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="120"/>
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="180"/>
                        <TableColumn fx:id="roleColumn" text="Role" prefWidth="80"/>
                        <TableColumn fx:id="userActionsColumn" text="Actions" prefWidth="200"/>
                    </columns>
                </TableView>
            </Tab>

            <Tab text="Categories">
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="15.0" bottom="15.0" left="15.0" right="15.0"/>
                    </padding>

                    <HBox spacing="10.0">
                        <TextField fx:id="newCategoryField" promptText="New category name"/>
                        <Button text="Add Category" onAction="#handleAddCategory"/>
                    </HBox>

                    <ListView fx:id="categoriesListView"/>
                    <Button
                            text="Delete Selected Category"
                            onAction="#handleDeleteCategory"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>