<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.divarclone.client.controller.LoginController"
      style="-fx-background-color: linear-gradient(to bottom, #1B2A4A, #D6EAF8);">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Login to Divar"/>

    <TextField fx:id="usernameField" promptText="Username" maxWidth="250"/>

    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250"/>

    <Button fx:id="loginButton" text="Login" onAction="#handleLogin" maxWidth="250"
            style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;" text=""/>

    <Hyperlink fx:id="registerLink" text="Don't have an account? Register" onAction="#handleGoToRegister"/>

</VBox>