<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.divarclone.client.controller.NewAdController">
    <padding>
        <Insets top="30.0" bottom="30.0" left="30.0" right="30.0"/>
    </padding>

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Create New Ad"/>

    <TextField fx:id="titleField" promptText="Title" maxWidth="300"/>

    <TextArea fx:id="descriptionArea" promptText="Description" maxWidth="300" prefRowCount="4"/>

    <TextField fx:id="priceField" promptText="Price" maxWidth="300"/>

    <TextField fx:id="cityField" promptText="City" maxWidth="300"/>

    <ComboBox fx:id="categoryComboBox" promptText="Category" maxWidth="300"/>

    <ImageView fx:id="imagePreview" fitWidth="150" fitHeight="150" preserveRatio="true"/>

    <Button text="Choose Image" onAction="#handleChooseImage" maxWidth="300"/>

    <Button text="Submit" onAction="#handleSubmit" maxWidth="300"/>

    <Button text="Cancel" onAction="#handleCancel" maxWidth="300"/>

    <Label fx:id="messageLabel" text=""/>

</VBox>