<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="15"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.divarclone.client.controller.RegisterController"
      style="-fx-background-color: linear-gradient(to bottom, #1B2A4A, #D6EAF8);">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Create Account"
           style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill: white;"/>

    <TextField fx:id="usernameField"
               promptText="Username"
               maxWidth="250"/>

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   maxWidth="250"/>

    <PasswordField fx:id="confirmPasswordField"
                   promptText="Confirm Password"
                   maxWidth="250"/>

    <TextField fx:id="phoneField"
               promptText="Phone Number"
               maxWidth="250"/>

    <TextField fx:id="emailField"
               promptText="Email"
               maxWidth="250"/>

    <Button fx:id="registerButton"
            text="Register"
            onAction="#handleRegister"
            maxWidth="250"
            style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>

    <Label fx:id="messageLabel"/>

    <Hyperlink text="Already have an account? Login"
               onAction="#handleBackToLogin"/>

</VBox>